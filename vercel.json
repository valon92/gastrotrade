{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm ci && npm run build:vercel",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.arontrade.net/api/:path*"
    },
    {
      "source": "/images/Uploads/:path*",
      "destination": "https://api.arontrade.net/images/Uploads/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://api.arontrade.net/storage/:path*"
    },
    {
      "source": "/((?!build/|images/|favicon|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/build/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
